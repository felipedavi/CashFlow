<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_chart_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/text_chart_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_chart_title"
            tools:background="#F0F0F0" />

        <LinearLayout
            android:id="@+id/layout_budget_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pieChart">

            <TextView
                android:id="@+id/text_needs_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#455A64"
                android:textSize="14sp"
                tools:text="Necessidades (50%): R$ 500,00 / R$ 1.000,00" />

            <ProgressBar
                android:id="@+id/progress_needs"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:progressDrawable="@drawable/rounded_border" />

            <TextView
                android:id="@+id/text_wants_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#455A64"
                android:textSize="14sp"
                tools:text="Desejos (30%): R$ 200,00 / R$ 600,00" />

            <ProgressBar
                android:id="@+id/progress_wants"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/text_investments_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#455A64"
                android:textSize="14sp"
                tools:text="Investimentos (20%): R$ 100,00 / R$ 400,00" />

            <ProgressBar
                android:id="@+id/progress_investments"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>